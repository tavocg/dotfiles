# mu init --maildir ~/.local/share/isync --my-address gustavo.calvo.cr@gmail.com --my-address gustavo.calvogutierrez@ucr.ac.cr --my-address team@atlascstg.com --my-address g.calvo@atlascstg.com
# mu index

IMAPAccount personal
Host imap.gmail.com
User gustavo.calvo.cr@gmail.com
PassCmd "pass personal/gmail.com/gustavo.calvo.cr@gmail.com-isync"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore personal-remote
Account personal

MaildirStore personal-local
SubFolders Verbatim
Path ~/.local/share/isync/personal/
Inbox ~/.local/share/isync/personal/Inbox

Channel personal
Far :personal-remote:
Near :personal-local:
Patterns * ![Gmail]* "[Gmail]/Sent Mail" "[Gmail]/Starred" "[Gmail]/All Mail" "[Gmail]/Trash" "[Gmail]/Drafts"
Create Both
#Expunge Both
SyncState *

IMAPAccount ucr
Host imap.ucr.ac.cr
User gustavo.calvogutierrez@ucr.ac.cr
PassCmd "pass edu/ucr.ac.cr/gustavo.calvogutierrez@ucr.ac.cr"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore ucr-remote
Account ucr

MaildirStore ucr-local
SubFolders Verbatim
Path ~/.local/share/isync/ucr/
Inbox ~/.local/share/isync/ucr/Inbox

Channel ucr
Far :ucr-remote:
Near :ucr-local:
Patterns INBOX Borradores Enviado Spam Papelera Archive
Create Both
#Expunge Both
SyncState *

IMAPAccount atlas
Host imap.hostinger.com
User team@atlascstg.com
PassCmd "pass work/g.calvo@atlascstg.com"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore atlas-remote
Account atlas

MaildirStore atlas-local
SubFolders Verbatim
Path ~/.local/share/isync/atlas/
Inbox ~/.local/share/isync/atlas/Inbox

Channel atlas
Far :atlas-remote:
Near :atlas-local:
Patterns *
Create Both
#Expunge Both
SyncState *
